# Server
NODE_ENV=development
PORT=3001

# Auth
JWT_SECRET=replace_with_a_long_random_string

# Database — MongoDB Atlas connection string
# Get this from https://www.mongodb.com/cloud/atlas (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/design-automation

# AI — used to generate design copy/concepts (POST /api/designs)
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# Canva — not wired yet (Phase 2), placeholder for when it is
CANVA_API_KEY=

# Stripe — test mode only, not wired to any UI action yet
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# CORS — the deployed frontend origin
FRONTEND_URL=http://localhost:3000
